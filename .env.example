# Cloudflare Pages Functions 環境変数
# Cloudflare Dashboard > Pages > Settings > Environment Variables に設定

# /stats エンドポイントの保護トークン（必須）
ADMIN_TOKEN=your-secret-token-here

# products.json の内容（デプロイ時に設定）
# src/generated/products.json の内容をそのまま貼り付けるか、
# gen スクリプトで生成したJSONを設定する
PRODUCTS_JSON={"products":[]}
